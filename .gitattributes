# Normalize all text files to LF in the repo (silences CRLF warnings on Windows)
* text=auto eol=lf

# Explicit text types
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf
_headers text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
